{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": [
        "../../*"
      ]
    },
    "typeRoots": [
      "./typings",
      "../../src/typings",
      "../../node_modules/@types",
      "../../game/**",
      "../../game/@codemirror/**"
    ]
    //   "types": [
    //     "extension",
    //     "get",
    //     "player",
    //     "game",
    //     "player2"
    //   ]
  },
  "include": [
    "source/**/*",
    "*.js",
    "typings/**/*"
  ],
  "exclude": [
    "node_modules",
    "audio",
    "image",
    "skin"
  ]
}